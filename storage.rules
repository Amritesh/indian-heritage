rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all media
    match /{allPaths=**} {
      allow read: if true;
    }

    // Authenticated editors/admins can upload to the uploads/ path
    match /uploads/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
